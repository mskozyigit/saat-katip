# ============================================================================
# Saat Katip — Ortam Değişkenleri (.env.example)
# ============================================================================
# Bu dosyayı .env olarak kopyalayın ve değerleri kendi Supabase projenize
# göre doldurun. .env dosyası ASLA Git'e commit edilmemelidir.
#
# Supabase Dashboard > Settings > API altından bu değerleri bulabilirsiniz.
# ============================================================================

# Supabase proje URL'si (Settings > API > Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (Settings > API > anon public)
# ⚠️ Bu anahtar tasarım gereği GİZLİ DEĞİLDİR, istemcide bulunması normaldir.
# Veri güvenliği RLS (Row Level Security) politikaları ile sağlanır.
# service_role anahtarı ASLA buraya yazılmamalıdır!
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# GitHub Actions Deployment için:
# Bu değişkenler GitHub Secrets'a da eklenmelidir:
#   Settings > Secrets and variables > Actions >
#     VITE_SUPABASE_URL
#     VITE_SUPABASE_ANON_KEY
# ============================================================================
